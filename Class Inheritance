    }
    
}

//speedometer interface
interface Speedometer {
        void setSpeed(double inSpeed);
        double getSpeed();
}

//base vehicle class
class Vehicle implements Speedometer {
        protected String brandName;
        protected double speed;
        protected int passengers;
        protected double cargoWeight;
        
        public Vehicle(String brand, double speed, int passengers, double cargo) {
            this.brandName = brand;
            this.speed = speed;
            this.passengers = passengers;
            this.cargoWeight = cargo;
        }
        
        public void setSpeed(double inSpeed) {
            speed = inSpeed;
        }
        
        public double getSpeed() {
            return speed;
        }
        
        public String getBrand() {
            return brandName;
        }
        
        public String toString() {
            return "Brand: " + brandName +
                    "Speed (mph): " + getSpeed() +
                    "Passengers: " + passengers +
                    "Cargo (lbs): " + cargoWeight;
            
        }
}

//car class (inherits vehicle)
class Car extends Vehicle {
        
        int wheels = 4;
        boolean spoiler = false;
        boolean stereo = false;
        double mpg;
        
        public Car(String brand, double speed, int passengers,
                   double cargo, double mpg) {
            super(brand, speed, passengers, cargo);
            this.mpg = mpg;
        }
        
        public void setSpoiler(boolean s) {
            spoiler = s;
        }
        
        public void setStereo(boolean s) {
            stereo = s;
        }
        
        //spolier increases speed
        @Override
        public double getSpeed() {
            if (spoiler)
                return super.getSpeed() + 20;
            return super.getSpeed();
        }
        
        //stereo reduces MPG
        public double getMPG() {
            if (stereo)
                return mpg - (mpg / 10);
            return mpg;
        }
        
        public String toString() {
            return super.toString() +
                    "MPG: " + getMPG();
        }  
}

//electric car
class TeslaModel3 extends Car {
        
        private double batteryCapacity;
        private double range; 
        
        public TeslaModel3(double speed, int passengers, double cargo,
                           double batteryCapacity, double range) {
            super("Tesla Model 3 (2025)", speed, passengers, cargo, 0);
            this.batteryCapacity = batteryCapacity;
            this.range = range;
        }
        
        public String toString() {
            return super.toString() +
                    "Battery (kWh): " + batteryCapacity +
                    "Range (mi): " + range;
        }
}

