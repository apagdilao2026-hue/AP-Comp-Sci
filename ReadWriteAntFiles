import java.io.BufferedWriter;
import java.io.BufferedReader;
import java.io.File;
import java.io.FileWriter;
import java.io.FileReader;
import java.io.IOException;
import java.util.Scanner;

public class Contacts {

    /**
     * @param args the command line arguments
     */
    public static void main(String[] args) {
         Scanner inputScanner = new Scanner(System.in);

        // Ask user for their information
        System.out.print("Enter your name: ");
        String name = inputScanner.nextLine();

        System.out.print("Enter your email: ");
        String email = inputScanner.nextLine();

        System.out.print("Enter your graduation year: ");
        String gradYear = inputScanner.nextLine();

        System.out.print("Enter your username: ");
        String username = inputScanner.nextLine();

        File contactsDir = new File("Contacts");

        //prepare the Contacts folder
        if (!contactsDir.exists()) {
            if (contactsDir.mkdirs()) {
                System.out.println("Contacts folder created at: " + contactsDir.getAbsolutePath());
            } else {
                System.err.println("Failed to create Contacts folder. Check permissions.");
                inputScanner.close();
                return;
            }
        }
        
        //file path to save contact info
        File contactFile = new File (contactsDir, "myContacts.txt");
        
        
        //write info into file
         try (BufferedWriter writer = new BufferedWriter(new FileWriter(contactFile, true))) {
            writer.write("Name: " + name + "\n");
            writer.write("Email: " + email + "\n");
            writer.write("Graduation Year: " + gradYear + "\n");
            writer.write("Username: " + username + "\n");
            writer.write("----------------------------\n"); //separator between entries
            System.out.println("\nYour information was succesfully saved!");
        } catch (IOException e) {
            System.err.println("Error writing to file: " + e.getMessage());
        }

        //read back the file
        System.out.println("\nReading saved contacts:");
         try (BufferedReader reader = new BufferedReader(new FileReader(contactFile))) {
            String line;
            while ((line = reader.readLine()) != null) {
                System.out.println(line);
            }
        } catch (IOException e) {
            System.err.println("Error reading from file: " + e.getMessage());
        }
         
         inputScanner.close();
    }
    
}

