/**
 *How to play:
 * 
 * 1. Enter your name when the game starts.
 * 
 * 2. You will be dealt 2 cards. The dealer will also get 2 cards, but only 1 card will be shown.
 * 
 * 3. Your goal is to get as close to 21 as possible
 *    without going over.
 * 
 * 4. Card values:
 *    - Number cards = face value (2–10)
 *    - Jack, Queen, King = 10
 *    - Ace = 11 (or 1 if needed to avoid busting)
 * 
 * 5. On your turn, choose:
 *    1 = Hit (draw another card)
 *    2 = Stand (end your turn)
 *
 * 6. If your total goes over 21, you bust and lose.
 *
 * 7. After you stand, the dealer plays automatically.
 *    The dealer must hit until reaching at least 17.
 *
 * 8. Whoever is closest to 21 without going over wins.
 *
 * 9. Your score (win or loss) is saved in:
 *    files/contacts.csv1
 *
 *    This file keeps a record of all game results.
 * 
 * 
 * @author APagdilao2026
 */
import java.util.Scanner;
import java.io.File;
import java.io.FileWriter;
import java.io.FileNotFoundException;
import java.io.IOException;

public class BlackjackGame {

    /**
     * @param args the command line arguments
     */
    public static void main(String[] args) {
        Scanner input = new Scanner (System.in);
        
        System.out.println("Welcome to Blackjack!");
        System.out.print("Enter your name: ");
        String playerName = input.nextLine();
        
        deck deck = new deck();
        Player player = new Player(playerName);
        Dealer dealer = new Dealer ();
        
        //initial cards
        player.addCard(deck.drawcard());
        player.addCard(deck.drawcard());
        
        dealer.addCard(deck.drawcard());
        dealer.addCard(deck.drawcard());
        
        //player turn
        boolean playerTurn = true;
        
        while (playerTurn) {
            System.out.println("\n" + player.getName() + "'s Hand:");
            player.showHand();
            
            System.out.println("\nDealer's Hand:");
            dealer.showFirstCard();
            
            if (player.getHandValue() > 21) {
                System.out.println("Bust! You lose.");
                saveScore(player.getName(), 0);
                return;
            }
            
            System.out.println("1. Hit");
            System.out.println("2. Stand");
            System.out.println("Choose: ");
            
            int choice;
            if (input.hasNextInt()) {
                choice = input.nextInt();
                input.nextLine();
            } else {
                System.out.println("Invalid input. Try again");
                input.nextLine();
                continue;
            }
            
            input.nextLine();
            
            if (choice ==  1) {
                player.addCard(deck.drawcard());
            } else if (choice == 2) {
                playerTurn = false;
            } else {
                System.out.println("Invalid choice. Please enter 1 or 2.");
            }
        }
        
        //dealer turn
        System.out.println("\nDealer's Turn");
        dealer.playTurn(deck);
        
        System.out.println("\nDealer's Final Hand:");
        dealer.showHand();
        
        int playerTotal = player.getHandValue();
        int dealerTotal = dealer.getHandValue();
        
        //results
        System.out.println("" + player.getName() + "'s Final Total:" + playerTotal);
        
        int score = 0;
        
        if (dealerTotal > 21) {
            System.out.println("Dealer busts! You win!");
            score = 1;
        } else if (playerTotal > dealerTotal) {
            System.out.println("You win!");
            score = 1;
        } else if (playerTotal < dealerTotal) {
            System.out.println("Dealer wins!");
            score = 0;
        } else {
            System.out.println("It's a tie!");
            score = 0;
        }
        
        saveScore(player.getName(), score);
        loadScores();
        
    }
    
    //file methods
     public static void saveScore(String name, int score) {
        File folder = new File("files");
        if (!folder.exists()) {
            folder.mkdir();
        }
         
         String filePath = "files/scores.csv";

        try {
            FileWriter writer = new FileWriter(filePath, true);
            writer.write(name + "," + score + "\n");
            writer.close();
        } catch (IOException e) {
            System.out.println("Error saving score.");
        }
    }

    public static void loadScores() {
        String filePath = "files/scores.csv";

        System.out.println("\n HIGH SCORES");

        try {
            File file = new File(filePath);
            Scanner fileScanner = new Scanner(file);

            while (fileScanner.hasNextLine()) {
                System.out.println(fileScanner.nextLine());
            }

            fileScanner.close();

        } catch (FileNotFoundException e) {
            System.out.println("Score file not found.");
        }
    } 
    
}
